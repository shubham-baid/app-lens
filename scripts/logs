#!/usr/bin/env bash
# Stream logs from AppLens services.
#
# Usage:
#   ./scripts/logs                  # follow all services
#   ./scripts/logs backend          # follow backend only
#   ./scripts/logs frontend         # follow frontend only
#   ./scripts/logs postgres         # follow database only
#   ./scripts/logs backend --tail=50  # last 50 lines of backend
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

SERVICE="${1:-}"
shift || true   # remaining args passed through to docker compose logs

case "$SERVICE" in
  ""|all)
    docker compose logs -f "$@"
    ;;
  backend|frontend|postgres)
    docker compose logs -f "$SERVICE" "$@"
    ;;
  *)
    echo "Unknown service: $SERVICE"
    echo ""
    echo "Usage: ./scripts/logs [SERVICE] [OPTIONS]"
    echo ""
    echo "Services: backend, frontend, postgres (default: all)"
    echo "Options:  --tail=N  show last N lines"
    exit 1
    ;;
esac
