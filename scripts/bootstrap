#!/usr/bin/env bash
# First-time project setup: copy env template, then start all services.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

echo "AppLens — first-time setup"
echo "--------------------------"

# 1. Environment file
if [ ! -f .env ]; then
  if [ ! -f .env.example ]; then
    echo "ERROR: .env.example not found. Cannot bootstrap." >&2
    exit 1
  fi
  cp .env.example .env
  echo "Created .env from .env.example."
  echo ""
  echo "Open .env and fill in the required values:"
  echo "  GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET"
  echo "  OPENAI_API_KEY"
  echo "  JWT_SECRET"
  echo "  POSTGRES_PASSWORD"
  echo ""
  read -rp "Press Enter once .env is configured, or Ctrl+C to cancel..."
else
  echo ".env already exists — skipping copy."
fi

echo ""

# 2. Build and start
bash "$ROOT/scripts/start"
